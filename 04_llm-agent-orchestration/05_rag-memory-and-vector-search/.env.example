# OpenAI API key for embedding and RAG examples.
OPENAI_API_KEY=your-openai-api-key

# Chat model used to generate final RAG answers.
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Embedding model used to convert text into vectors.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local pgvector database connection.
DATABASE_URL=postgresql://rag_user:rag_password@localhost:5433/rag_db
