# 04_supabase-ai-mini-project 팀 프로젝트용 .env.example 템플릿입니다.
# 실제 key를 이 파일에 넣지 않습니다.
# 팀 프로젝트 폴더로 복사한 뒤 파일명을 .env.example로 사용합니다.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

GEMINI_API_KEY=replace-with-your-gemini-api-key

# OpenAI는 선택 비교 실습에서만 사용합니다.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Streamlit이 호출할 FastAPI 주소입니다.
API_BASE_URL=http://127.0.0.1:8000
