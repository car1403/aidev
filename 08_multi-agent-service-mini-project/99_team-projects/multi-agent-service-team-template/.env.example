# 현재 실행 환경입니다.
APP_ENV=local

# 선택 확장용 OpenAI API Key입니다.
# 실제 값은 .env에만 적고 GitHub에는 올리지 않습니다.
OPENAI_API_KEY=your-openai-api-key

# OpenAI 예제 확장 시 사용할 기본 모델입니다.
OPENAI_MODEL=gpt-4.1-mini

# backend FastAPI 포트입니다.
BACKEND_PORT=8000

# frontend Streamlit 포트입니다.
FRONTEND_PORT=8801

# monitor Streamlit 포트입니다.
MONITOR_PORT=8802
