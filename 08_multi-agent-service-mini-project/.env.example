# 실행 환경 이름입니다.
# local, dev, prod처럼 현재 실행 환경을 구분할 때 사용합니다.
APP_ENV=local

# OpenAI API Key 예시입니다.
# 실제 값은 .env 파일에만 적고 GitHub에는 올리지 않습니다.
OPENAI_API_KEY=your-openai-api-key

# 04~07 과정에서 OpenAI 예제의 기본 모델로 사용하는 값입니다.
OPENAI_MODEL=gpt-4.1-mini

# backend FastAPI 서비스 포트입니다.
BACKEND_PORT=8000

# frontend Streamlit 서비스 포트입니다.
FRONTEND_PORT=8801

# monitor Streamlit 대시보드 포트입니다.
MONITOR_PORT=8802
