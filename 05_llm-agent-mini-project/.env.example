# OpenAI API key for LLM Agent examples.
OPENAI_API_KEY=your-openai-api-key

# Chat model used by agent examples.
OPENAI_MODEL=gpt-4.1-mini

# Optional local LLM settings when using Ollama with docker run.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional pgvector connection when using local RAG memory with docker run.
PGVECTOR_DATABASE_URL=postgresql://rag_user:rag_password@localhost:5433/rag_db
