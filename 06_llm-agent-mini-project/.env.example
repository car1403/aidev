# OpenAI API Key입니다.
# API Key가 없어도 Mock data 기반 Agent 흐름은 일부 실행할 수 있습니다.
OPENAI_API_KEY=your-openai-api-key

# 04~07 과정에서 통일해 사용하는 OpenAI 기본 모델입니다.
OPENAI_MODEL=gpt-4.1-mini

# 선택 사항입니다.
# OpenAI API 대신 Docker로 실행한 Ollama/Llama를 실험할 때 사용합니다.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# 선택 사항입니다.
# 팀 프로젝트에서 로컬 pgvector 기반 RAG/Memory를 사용할 때만 설정합니다.
PGVECTOR_DATABASE_URL=postgresql://rag_user:rag_password@localhost:5433/rag_db
